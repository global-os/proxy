{
  "name": "nodeproxy-backend",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev:backend": "tsx src/index.tsx",
    "dev:frontend": "cd src/frontend; npm run-script dev",
    "build:backend": "tsc",
    "build:frontend": "cd src/frontend; npm run-script build",
    "build:www": "cd src/www && npm install && npm run build",
    "build": "node scripts/write-build-version.mjs && npm run-script build:www && npm run-script build:frontend && npm run-script build:backend",
    "start": "node dist/src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier -w src/frontend/src/**/*.{ts,tsx} **/*.{ts,tsx} ./drizzle.config.ts",
    "db:migrate": "node scripts/apply-pending-migrations.mjs",
    "bundle:helloworld-yjs": "node scripts/bundle-helloworld-yjs.mjs",
    "vercel-build": "npm install && (cd src/frontend && npm install --legacy-peer-deps) && (cd src/www && npm install) && node scripts/apply-pending-migrations.mjs && node scripts/write-build-version.mjs && npm run build && node scripts/verify-frontend-bundle.mjs && node scripts/sync-public-assets.mjs"
  },
  "version": "1.0.0",
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "main": "index.js",
  "type": "module",
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@hono/node-server": "^2.0.6",
    "@types/node": "^25.0.1",
    "@types/pg": "^8.16.0",
    "@types/tar": "^7.0.87",
    "@vercel/functions": "^2.2.13",
    "better-auth": "^1.4.7",
    "bunx": "^0.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fp-ts": "^2.16.11",
    "hono": "^4.10.8",
    "jsdom": "^27.3.0",
    "kysely": "^0.28.9",
    "pg": "^8.16.3",
    "postmark": "^4.0.7",
    "prettier": "^3.7.4",
    "styled-components": "^6.1.19",
    "tar": "^7.5.16",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@tanstack/router-cli": "^1.157.16",
    "@types/picomatch": "^3.0.0"
  }
}
