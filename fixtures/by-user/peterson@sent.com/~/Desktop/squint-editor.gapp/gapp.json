{
  "name": "squint-editor",
  "icon": "wizard",
  "version": "1.0.1",
  "entry": "index.html",
  "type": "module",
  "compile": {
    "squint": {
      "source": "app.cljs",
      "output": "app.js",
      "externals": {
        "yjs": "Y"
      }
    }
  },
  "dependencies": {
    "yjs": {
      "version": "13.6.20",
      "source": "bundled",
      "path": "yjs.js",
      "format": "iife",
      "global": "Y",
      "order": 1
    }
  }
}